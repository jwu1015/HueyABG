# OpenRouter (https://openrouter.ai) — used by the chat route
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: for rankings on openrouter.ai
# OPENROUTER_HTTP_REFERER=https://yoursite.com
# OPENROUTER_TITLE=HuyABG

# RAG with Pinecone (optional). When set, the chat uses your content for context.
# Get API key from https://app.pinecone.io. Index must be dimension 1536, metric cosine.
# PINECONE_API_KEY=...
# PINECONE_INDEX=huey-rag
# Optional: set PINECONE_HOST to your index host URL to skip a lookup (e.g. huey-rag-xxx.svc.region.pinecone.io)
# PINECONE_HOST=huy-rag-xxx.svc.region.pinecone.io

# Optional: RAG with pgvector (e.g. DATABASE_URL for Neon/Supabase)
# DATABASE_URL=postgresql://...
